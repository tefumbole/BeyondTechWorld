# AlphaBridge API — Hostinger MySQL
PORT=3003
NODE_ENV=production
CORS_ORIGIN=https://alpha-bridge.net
APP_URL=https://alpha-bridge.net
JWT_SECRET=change_this_to_a_long_random_string

# Hostinger MySQL (hPanel → Databases → MySQL)
# Use Remote MySQL hostname from Hostinger, NOT localhost, when API runs on VPS
DB_HOST=srvXXXX.hstgr.io
DB_PORT=3306
DB_USER=u123456789_abt
DB_PASSWORD=your_mysql_password
DB_NAME=u123456789_alphabridge

# Wasender (server-side — move keys here during migration)
WASENDER_API_KEY=
WASENDER_BASE_URL=https://wasenderapi.com/api
COMPANY_NAME=Alpha Bridge Technologies Ltd

# SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

SEED_ADMIN_EMAIL=admin@alpha-bridge.net
SEED_ADMIN_PASSWORD=ChangeMe@123456
