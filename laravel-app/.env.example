APP_NAME="Beyond Enterprise"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION="BCL V.2.1.4"

# Beyond portal: skip WhatsApp OTP at login (LOCAL ONLY — keep false in production)
BEYOND_SKIP_OTP=false

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Messaging channels (Settings → Messaging Settings)
MESSAGING_WHATSAPP_ENABLED=true
MESSAGING_SMS_ENABLED=true

# WhatsApp provider: WASENDER | TWILIO
# Note: OTP and Announcements ALWAYS use Wasender (OTP Twilio template not approved).
# TWILIO is for approved Content Templates (e.g. admission/hired) and optional status SID.
WHATSAPP_SERVICE=WASENDER
WHATSAPP_DEFAULT_COUNTRY_CODE=237
WHATSAPP_TWILIO_FALLBACK_WASENDER=true
COMPANY_NAME=Beyond Enterprise

# WasenderAPI
WASENDER_API_KEY=
WASENDER_SESSION_ID=
WASENDER_BASE_URL=https://wasenderapi.com/api
WASENDER_MIN_SEND_INTERVAL_MS=6000
WASENDER_TEXT_TO_DOCUMENT_DELAY_MS=6000

# Twilio WhatsApp (Content Templates) — used when WHATSAPP_SERVICE=TWILIO
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_CONTENT_SID_ADMISSION=HX47150e179fdbab79738d060fb0ac6415
# TWILIO_WHATSAPP_CONTENT_SID_OTP=  # unused — OTP always uses Wasender
TWILIO_WHATSAPP_CONTENT_SID_STATUS=

# SMS gateway: twilio | clickatell
SMS_GATEWAY=twilio
ACCOUNT_SID=
AUTH_TOKEN=
TWILIO_NUMBER=
CLICKATELL_API_KEY=

# Legacy aliases still supported by config/services.php:
# WASENDER_API_URL=https://wasenderapi.com/api
# WHATSAPP_SEND_INTERVAL=6
# Twilio_Number=  (legacy; prefer TWILIO_NUMBER)

ULTRAMSG_INSTANCE=
ULTRAMSG_TOKEN=
